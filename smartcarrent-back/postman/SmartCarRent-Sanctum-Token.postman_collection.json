{
  "info": {
    "name": "SmartCarRent Sanctum Token Flow",
    "description": "Token-based authentication flow for Laravel Sanctum (Bearer token).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000/api",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "reservationId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "paiementId",
      "value": "1",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Client (stores token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Client Sanctum\",\n  \"email\": \"client.sanctum+{{$timestamp}}@example.com\",\n  \"password\": \"Client@2026!\",\n  \"password_confirmation\": \"Client@2026!\",\n  \"permis_conduire\": \"PERMIS-{{$randomInt}}\",\n  \"telephone\": \"0600000000\",\n  \"adresse\": \"Casablanca\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('register ok', function () { pm.response.to.have.status(201); });",
                  "var json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('accessToken', json.token); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Admin (stores token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test-admin@example.com\",\n  \"password\": \"Admin@2026!\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login ok', function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('accessToken', json.token); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Get Dashboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/dashboard"
          }
        },
        {
          "name": "Logout (clear token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/logout"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('accessToken', '');"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Protected API",
      "item": [
        {
          "name": "List Voitures",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/voitures?per_page=10"
          }
        },
        {
          "name": "List Reservations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/reservations?per_page=10"
          }
        },
        {
          "name": "List Paiements",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/paiements?per_page=10"
          }
        },
        {
          "name": "Admin List Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/users?per_page=10"
          }
        },
        {
          "name": "Validate Payment (admin)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/paiements/{{paiementId}}/validate"
          }
        },
        {
          "name": "Refund Payment (admin)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/paiements/{{paiementId}}/refund"
          }
        }
      ]
    }
  ]
}
